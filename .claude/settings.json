{
  "model": "claude-haiku-4-5-20251001",
  "permissions": {
    "allow": [
      "Bash(python*)",
      "Bash(pip install*)",
      "Bash(pip show*)",
      "Bash(pytest*)",
      "Bash(airflow*)",
      "Bash(conda*)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(mkdir -p *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(systemctl status airflow)",
      "Bash(systemctl enable airflow)",
      "Read(**)",
      "Write(**)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(sudo rm -rf *)",
      "Bash(curl * | bash *)",
      "Bash(wget * | sh *)"
    ]
  },
  "env": {
    "PYTHONPATH": "${workspaceRoot}",
    "AIRFLOW_HOME": "${env:HOME}/airflow"
  }
}
